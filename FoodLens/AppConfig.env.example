# Copy values into AppConfig.env and keep the real file out of git.
# Switch provider here: gemini, openai, cohere or mistral
AI_PROVIDER=gemini

# Gemini config
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite

# OpenAI config
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_FALLBACK_MODEL=

# Cohere config
COHERE_API_KEY=
COHERE_MODEL=command-a-vision-07-2025
COHERE_FALLBACK_MODEL=

# Mistral config
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
MISTRAL_FALLBACK_MODEL=ministral-8b-2512
